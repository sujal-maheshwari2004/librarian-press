{
  "name": "librarian-pre-130M",
  "mode": "pretrain",
  "model": {
    "vocab_size": 32000,
    "dim": 768,
    "n_layers": 12,
    "n_heads": 12,
    "hidden_dim": 3072,
    "max_seq_len": 1024,
    "dropout": 0.0,
    "rope_theta": 10000.0,
    "tie_embeddings": true
  },
  "tokenizer": {
    "path": "runs/librarian-pre-130M/tokenizer/tokenizer.json",
    "train_if_missing": true,
    "vocab_size": 32000,
    "min_frequency": 2,
    "special_tokens": ["<pad>", "<bos>", "<eos>", "<unk>"]
  },
  "pretrain": {
    "data": {
      "inputs": ["./data/corpus/*.parquet", "./data/extra/*.txt"],
      "format": "auto",
      "text_column": "text",
      "txt_granularity": "line",
      "seq_len": 1024,
      "val_frac": 0.005,
      "test_frac": 0.001
    },
    "training": {
      "lr": 3e-4, "min_lr": 3e-5,
      "warmup_steps": 2000, "total_steps": 100000,
      "batch_size": 32, "grad_accum": 4,
      "weight_decay": 0.1, "mixed_precision": true,
      "eval_interval": 2000, "save_interval": 5000, "device": "cuda"
    }
  }
}
