{
  "name": "librarian-qa-lora",
  "mode": "sft",
  "model": { "config_path": "./configs/model_130M.json" },
  "tokenizer": {
    "path": "./artifacts/tokenizer.json",
    "train_if_missing": false,
    "vocab_size": 32000
  },
  "sft": {
    "finetune": {
      "method": "lora",
      "base_checkpoint": "./artifacts/pretrained.pt",
      "lora": { "rank": 8, "alpha": 16, "dropout": 0.05 },
      "eval_metric": "exact_match"
    },
    "data": {
      "inputs": {
        "train": ["./data/squad/train/*.parquet"],
        "val": ["./data/squad/val/*.parquet"]
      },
      "format": "parquet",
      "prompt_template": "Context: {context}\nQuestion: {question}\nAnswer:",
      "completion_field": "answers.text[0]",
      "max_prompt_len": 384,
      "max_completion_len": 64
    },
    "training": {
      "lr": 3e-4, "min_lr": 3e-5,
      "warmup_steps": 200, "total_steps": 5000,
      "batch_size": 16, "grad_accum": 4,
      "weight_decay": 0.01, "mixed_precision": true,
      "eval_interval": 500, "save_interval": 1000, "device": "cuda"
    }
  }
}
