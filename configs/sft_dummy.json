{
  "name": "librarian-dummy-sft",
  "mode": "sft",
  "model": {
    "vocab_size": 4000,
    "dim": 64,
    "n_layers": 2,
    "n_heads": 2,
    "hidden_dim": 128,
    "max_seq_len": 64,
    "dropout": 0.0,
    "rope_theta": 10000.0,
    "tie_embeddings": true
  },
  "tokenizer": {
    "path": "runs/librarian-dummy-pre/tokenizer/tokenizer.json",
    "train_if_missing": false,
    "vocab_size": 4000
  },
  "sft": {
    "finetune": {
      "method": "lora",
      "base_checkpoint": "runs/librarian-dummy-pre/checkpoints/pretrain/last.pt",
      "lora": { "rank": 8, "alpha": 16, "dropout": 0.05 },
      "eval_metric": "f1"
    },
    "data": {
      "inputs": {
        "train": ["tests/fixtures/sft/train.jsonl"],
        "val": ["tests/fixtures/sft/val.parquet"]
      },
      "format": "auto",
      "prompt_template": "Q: {question}\nA:",
      "completion_field": "answer",
      "max_prompt_len": 32,
      "max_completion_len": 16
    },
    "training": {
      "lr": 3e-4, "min_lr": 3e-5,
      "warmup_steps": 5, "total_steps": 30,
      "batch_size": 4, "grad_accum": 1,
      "weight_decay": 0.01, "mixed_precision": false,
      "eval_interval": 15, "save_interval": 15, "device": "cpu"
    }
  }
}
